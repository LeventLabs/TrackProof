{
  "name": "@trackproof/skill",
  "version": "0.0.0",
  "description": "TrackProof installable agent skill + installer (copies SKILL.md into coding-agent skills dirs).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --test \"dist/**/*.test.js\""
  }
}
