{
  "name": "trackproof",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Verifiable track records for AI trading agents.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "trackproof": "node packages/cli/dist/index.js",
    "evidence:tick": "node scripts/evidence-tick.mjs",
    "certifiable:demo": "node scripts/certifiable-demo.mjs",
    "test": "npm run build && node --test \"packages/*/dist/**/*.test.js\"",
    "test:contracts": "forge test --root contracts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
